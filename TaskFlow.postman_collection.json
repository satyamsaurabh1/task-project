{
	"info": {
		"_postman_id": "taskflow-api-collection",
		"name": "TaskFlow API",
		"description": "Complete API collection for the TaskFlow Task Management System.\n\nSetup:\n1. Set the `baseUrl` variable to your backend URL (default: http://localhost:5000/api)\n2. Register or Login to get a JWT token\n3. The token is auto-saved to the `authToken` variable after login/register",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api",
			"type": "string"
		},
		{
			"key": "authToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "projectId",
			"value": "",
			"type": "string"
		},
		{
			"key": "taskId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints — register, login, logout, get current user, list users.",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('authToken', jsonData.token);",
									"    console.log('Token saved after registration');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"Password@123\",\n    \"role\": \"user\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new user. On success, the JWT token is auto-saved to the `authToken` variable."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('authToken', jsonData.token);",
									"    console.log('Token saved after login');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"Password@123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Login with email and password. On success, the JWT token is auto-saved to the `authToken` variable."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						},
						"description": "Semantic logout endpoint. JWT invalidation is handled client-side."
					},
					"response": []
				},
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "me"]
						},
						"description": "Get the currently authenticated user's profile."
					},
					"response": []
				},
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/users",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "users"]
						},
						"description": "List all users (name, email, role). Used for task assignment dropdowns."
					},
					"response": []
				}
			]
		},
		{
			"name": "Projects",
			"description": "Project CRUD endpoints and dashboard statistics.",
			"item": [
				{
					"name": "Get Dashboard Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/stats/overview",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "stats", "overview"]
						},
						"description": "Get dashboard statistics: total projects, total tasks, completed tasks, pending tasks."
					},
					"response": []
				},
				{
					"name": "Get All Projects",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects",
							"host": ["{{baseUrl}}"],
							"path": ["projects"]
						},
						"description": "Get all projects the current user is a member of or has created. Admins see all projects."
					},
					"response": []
				},
				{
					"name": "Create Project",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('projectId', jsonData._id);",
									"    console.log('Project ID saved: ' + jsonData._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My First Project\",\n    \"description\": \"A sample project to test the API\",\n    \"members\": []\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects",
							"host": ["{{baseUrl}}"],
							"path": ["projects"]
						},
						"description": "Create a new project. The `projectId` is auto-saved for subsequent requests."
					},
					"response": []
				},
				{
					"name": "Get Project by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						},
						"description": "Get a single project by its ID. Requires membership or admin role."
					},
					"response": []
				},
				{
					"name": "Update Project",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Updated Project Title\",\n    \"description\": \"Updated description\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						},
						"description": "Update a project. Only the project owner or an admin can update."
					},
					"response": []
				},
				{
					"name": "Delete Project",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}"]
						},
						"description": "Delete a project and all its tasks. Only the project owner or an admin can delete."
					},
					"response": []
				}
			]
		},
		{
			"name": "Tasks",
			"description": "Task CRUD endpoints — nested under a project.",
			"item": [
				{
					"name": "Get All Tasks",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"]
						},
						"description": "Get all tasks in a project. Requires project membership or admin role."
					},
					"response": []
				},
				{
					"name": "Create Task",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('taskId', jsonData._id);",
									"    console.log('Task ID saved: ' + jsonData._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Design landing page\",\n    \"description\": \"Create wireframes and mockups for the landing page\",\n    \"status\": \"pending\",\n    \"priority\": \"high\",\n    \"dueDate\": \"2026-04-01\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"]
						},
						"description": "Create a new task in a project. The `taskId` is auto-saved for subsequent requests."
					},
					"response": []
				},
				{
					"name": "Get Task by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
						},
						"description": "Get a single task by its ID within a project."
					},
					"response": []
				},
				{
					"name": "Update Task",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Design landing page - REVISED\",\n    \"status\": \"in-progress\",\n    \"priority\": \"medium\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
						},
						"description": "Update a task. Supports partial updates — only include fields you want to change."
					},
					"response": []
				},
				{
					"name": "Delete Task",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
						},
						"description": "Delete a task from a project."
					},
					"response": []
				}
			]
		},
		{
			"name": "Health",
			"description": "Server health check.",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Check if the backend server is running."
					},
					"response": []
				}
			]
		}
	]
}
